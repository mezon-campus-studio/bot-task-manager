{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./",
    "baseUrl": ".",
    "outDir": "dist",
    "types": ["jest"],
    "noEmit": true,
    "incremental": false,
    "tsBuildInfoFile": null
  },
  "include": ["src"],
  "exclude": [
